# -------------------------------------------------------------------
# Semantic Search Engine — environment variables
# Copy this file to .env and fill in your values.
# -------------------------------------------------------------------

# Hugging Face model ID for the bi-encoder (dense retrieval / recall stage).
# Passages are pre-encoded and stored in the FAISS index.
# Example: sentence-transformers/all-MiniLM-L6-v2
BI_ENCODER_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Hugging Face model ID for the cross-encoder (re-ranking / precision stage).
# Scores individual (query, passage) pairs; run only on the top-K candidates.
# Example: cross-encoder/ms-marco-MiniLM-L-6-v2
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Filesystem path where the FAISS flat-IP index is persisted / loaded from.
FAISS_INDEX_PATH=data/indices/corpus.index

# Number of candidates fetched from the FAISS index (recall stage).
# Should be much larger than TOP_K_RERANK so the re-ranker has room to work.
TOP_K_RETRIEVE=100

# Number of results returned to the caller after cross-encoder re-ranking.
TOP_K_RERANK=10
