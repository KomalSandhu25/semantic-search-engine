# Bi-encoder model (used for fast first-stage retrieval)
BI_ENCODER_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Cross-encoder model (used for precision re-ranking)
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Path where FAISS index files are stored / loaded from
FAISS_INDEX_PATH=data/indices/corpus.index

# Number of candidates to retrieve with the bi-encoder (recall stage)
TOP_K_RETRIEVE=100

# Number of top results to return after cross-encoder re-ranking (precision stage)
TOP_K_RERANK=10
