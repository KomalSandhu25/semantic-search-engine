# -------------------------------------------------------
# Semantic Search Engine — environment configuration
# Copy this file to .env and fill in the values.
# -------------------------------------------------------

# Hugging Face model name for the bi-encoder (retrieval stage).
# Controls recall: higher-quality models improve recall but are slower.
# Default: all-MiniLM-L6-v2 (fast, 384-dim embeddings)
BI_ENCODER_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Hugging Face model name for the cross-encoder (reranking stage).
# Controls precision: applied only to the top-K candidates from bi-encoder.
# Default: cross-encoder/ms-marco-MiniLM-L-6-v2
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Absolute path (or relative to project root) for the persisted FAISS index.
# Created on first index build; reloaded on subsequent runs.
FAISS_INDEX_PATH=data/index/faiss.index

# Number of candidate documents returned by the bi-encoder before reranking.
# Higher values improve recall at the cost of cross-encoder latency.
TOP_K_RETRIEVE=100

# Number of final results surfaced to the user after cross-encoder reranking.
# Must be <= TOP_K_RETRIEVE.
TOP_K_RERANK=10
